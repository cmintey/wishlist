# If behind a reverse proxy, set this to your domain
# i.e. https://wishlist.your-domain.org
ORIGIN=
# Database connection string. SQLite is the zero-config default - leave this
# unset (or a file: URL) and Wishlist will store its data in
# /usr/src/app/data/prod.db. To use an external Postgres database instead,
# set this to a postgres:// or postgresql:// connection string, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/wishlist?sslmode=require
# See the "Postgres support" section of the README for details.
DATABASE_URL=
# Hours until signup and password reset tokens expire
TOKEN_TIME=72
# The currency to use when a product search does not return a currency
DEFAULT_CURRENCY=USD
# Set the logging level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
# Maxinum image size that can be uploaded (in bytes)
MAX_IMAGE_SIZE=5000000